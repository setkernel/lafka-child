{
	"name": "lafka-child",
	"version": "6.0.6",
	"private": true,
	"description": "Lafka Child Theme",
	"scripts": {
		"lint:js": "eslint .",
		"lint:js:fix": "eslint . --fix",
		"lint:css": "stylelint '**/*.css'",
		"lint:css:fix": "stylelint '**/*.css' --fix",
		"lint": "npm run lint:js && npm run lint:css",
		"lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
		"sync-version": "node scripts/sync-version.mjs",
		"check-version": "node scripts/sync-version.mjs --check",
		"version": "node scripts/sync-version.mjs --stage"
	},
	"versionSync": [
		{
			"file": "style.css",
			"pattern": "^\\s*Version:\\s*(\\d+\\.\\d+\\.\\d+[^\\s]*)",
			"flags": "m",
			"required": true
		}
	],
	"devDependencies": {
		"eslint": "^10.6.0",
		"@eslint/js": "^10.0.1",
		"globals": "^17.7.0",
		"stylelint": "^17.14.0",
		"@wordpress/stylelint-config": "^23.41.0"
	}
}
